# ---- LLM Provider ----
# Options: ollama, anthropic, openai, gemini
RECALL_LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Anthropic (cloud fallback)
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (cloud fallback)
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4o-mini

# Gemini (cloud fallback)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# Generation reliability (all providers)
RECALL_GENERATE_RETRIES=3
RECALL_GENERATE_BACKOFF_SECONDS=1.5
RECALL_OLLAMA_GENERATE_TIMEOUT_SECONDS=180

# Embedding reliability (ollama)
RECALL_EMBED_RETRIES=3
RECALL_EMBED_BACKOFF_SECONDS=1.5

# ---- Qdrant ----
QDRANT_HOST=http://localhost:6333
QDRANT_COLLECTION=recall_docs

# ---- n8n Webhook ----
N8N_HOST=http://localhost:5678
RECALL_WEBHOOK_PATH=/webhook/recall-ingest

# ---- Paths ----
DATA_INCOMING=/home/jaydreyer/recall-local/data/incoming
DATA_PROCESSED=/home/jaydreyer/recall-local/data/processed
DATA_ARTIFACTS=/home/jaydreyer/recall-local/data/artifacts

# ---- Email Ingestion (Phase 1) ----
RECALL_EMAIL_HOST=imap.gmail.com
RECALL_EMAIL_USER=your-recall-inbox@gmail.com
RECALL_EMAIL_PASSWORD=app-password-here

# ---- Optional ----
RECALL_API_KEY=
RECALL_API_SERVER_LOCAL=http://localhost:8090
RECALL_API_SERVER_AI_LAB=http://100.116.103.78:8090
RECALL_API_RATE_LIMIT_WINDOW_SECONDS=60
RECALL_API_RATE_LIMIT_MAX_REQUESTS=120
RECALL_API_CORS_ORIGINS=*
RECALL_VAULT_PATH=~/obsidian-vault
RECALL_VAULT_SYNC_MODE=watch
RECALL_VAULT_DEBOUNCE_SEC=5
RECALL_VAULT_EXCLUDE_DIRS=_attachments,.obsidian,.trash,recall-artifacts
RECALL_VAULT_WRITE_BACK=false
RECALL_VAULT_IS_SYNCED=true
TAILSCALE_IP=
