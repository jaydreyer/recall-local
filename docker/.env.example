# ==============================================================================
# Recall.local Environment Configuration
# ==============================================================================
# Copy to docker/.env and fill in values for your deployment.
# All variables have sensible defaults — only API keys need to be set
# for the features you want to enable.
# ==============================================================================

# ==============================================================================
# LLM Provider
# ==============================================================================
# Which provider to use for text generation: ollama, anthropic, openai, gemini
RECALL_LLM_PROVIDER=ollama

# --- Ollama (local, default) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Anthropic (cloud fallback) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI (cloud fallback) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Gemini (cloud fallback) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ==============================================================================
# Generation Reliability
# ==============================================================================
RECALL_GENERATE_RETRIES=3
RECALL_GENERATE_BACKOFF_SECONDS=1.5
RECALL_OLLAMA_GENERATE_TIMEOUT_SECONDS=180
RECALL_OLLAMA_NUM_CTX=8192

# ==============================================================================
# Embedding Configuration
# ==============================================================================
# Embeddings always use Ollama (local-first), regardless of generation provider.
RECALL_EMBED_RETRIES=3
RECALL_EMBED_BACKOFF_SECONDS=1.5
RECALL_EMBED_MAX_CHARS=1200
RECALL_EMBED_MIN_CHARS=384

# ==============================================================================
# Chunking
# ==============================================================================
RECALL_CHUNK_TOKENS=400
RECALL_CHUNK_OVERLAP=60

# ==============================================================================
# RAG Retrieval & Answer Shaping
# ==============================================================================
# Retrieval mode: vector, hybrid, bm25
RECALL_RAG_RETRIEVAL_MODE=vector
RECALL_RAG_TOP_K=5
RECALL_RAG_MIN_SCORE=0.2

# Hybrid retrieval tuning (only used when RECALL_RAG_RETRIEVAL_MODE=hybrid)
RECALL_RAG_HYBRID_ALPHA=0.65
RECALL_RAG_HYBRID_CANDIDATE_MULTIPLIER=4

# Optional lightweight reranking
RECALL_RAG_ENABLE_RERANK=false
RECALL_RAG_RERANK_WEIGHT=0.35

# Answer generation limits
RECALL_RAG_TEMPERATURE=0.2
RECALL_RAG_MAX_TOKENS=640
RECALL_RAG_SUMMARY_MAX_TOKENS=900
RECALL_RAG_SUMMARY_TOP_K=20
RECALL_RAG_MAX_RETRIES=1

# ==============================================================================
# Qdrant Vector Database
# ==============================================================================
QDRANT_HOST=http://localhost:6333
QDRANT_COLLECTION=recall_docs
EMBEDDING_DIMENSION=768

# ==============================================================================
# SQLite Database
# ==============================================================================
RECALL_DB_PATH=data/recall.db

# ==============================================================================
# Data Paths
# ==============================================================================
DATA_INCOMING=data/incoming
DATA_PROCESSED=data/processed
DATA_ARTIFACTS=data/artifacts

# ==============================================================================
# n8n Workflow Engine
# ==============================================================================
N8N_HOST=http://localhost:5678
RECALL_WEBHOOK_PATH=/webhook/recall-ingest

# ==============================================================================
# FastAPI Bridge Configuration
# ==============================================================================
RECALL_API_KEY=
RECALL_API_SERVER_LOCAL=http://localhost:8090
RECALL_API_RATE_LIMIT_WINDOW_SECONDS=60
RECALL_API_RATE_LIMIT_MAX_REQUESTS=120
RECALL_MAX_UPLOAD_MB=50

# Comma-separated list of allowed CORS origins
RECALL_API_CORS_ORIGINS=http://localhost:8170,http://localhost:3001

# ==============================================================================
# Email Ingestion (Phase 1)
# ==============================================================================
RECALL_EMAIL_HOST=imap.gmail.com
RECALL_EMAIL_USER=
RECALL_EMAIL_PASSWORD=

# ==============================================================================
# Meeting Action Items (Phase 2)
# ==============================================================================
RECALL_MEETING_MAX_RETRIES=1
RECALL_MEETING_TEMPERATURE=0.2

# ==============================================================================
# Obsidian Vault Sync (Phase 5)
# ==============================================================================
RECALL_VAULT_PATH=~/obsidian-vault
RECALL_VAULT_SYNC_MODE=watch
RECALL_VAULT_DEBOUNCE_SEC=5
RECALL_VAULT_EXCLUDE_DIRS=_attachments,.obsidian,.trash,recall-artifacts
RECALL_VAULT_WRITE_BACK=false
RECALL_VAULT_IS_SYNCED=true

# ==============================================================================
# Job Search (Phase 6)
# ==============================================================================
RECALL_JOBS_ENABLED=true
RECALL_JOBS_CLOUD_FALLBACK=false
RECALL_JOBS_CLOUD_PROVIDER=anthropic
RECALL_JOBS_CLOUD_MODEL=claude-sonnet-4-5-20250929

# Job discovery API keys (optional — each enables one additional source)
RECALL_ADZUNA_APP_ID=
RECALL_ADZUNA_APP_KEY=
RECALL_SERPAPI_API_KEY=

# Phase 6 local model overrides
RECALL_PHASE6_EVAL_LOCAL_MODEL=llama3.2:3b
RECALL_PHASE6_METADATA_MODEL=llama3.2:3b

# Phase 6 cache TTLs (seconds)
RECALL_PHASE6_JOBS_CACHE_SECONDS=15
RECALL_PHASE6_COMPANY_CACHE_SECONDS=180
RECALL_PHASE6_GAP_CACHE_SECONDS=300
RECALL_PHASE6_GAP_EMBED_LIMIT=24

# ==============================================================================
# Notifications
# ==============================================================================
# Telegram bot for job alerts and uptime notifications
RECALL_TELEGRAM_BOT_TOKEN=
RECALL_TELEGRAM_CHAT_ID=

# Dashboard port
RECALL_DASHBOARD_PORT=3001

# Uptime alerting (optional)
RECALL_UPTIME_ALERT_WEBHOOK_URL=
RECALL_UPTIME_ALERT_TELEGRAM_BOT_TOKEN=
RECALL_UPTIME_ALERT_TELEGRAM_CHAT_ID=
RECALL_UPTIME_NOTIFY_ON_SUCCESS=false

# ==============================================================================
# Evaluation
# ==============================================================================
RECALL_EVAL_MAX_LATENCY_MS=15000
RECALL_EVAL_WEBHOOK_URL=

# ==============================================================================
# Observability — OpenTelemetry
# ==============================================================================
RECALL_OTEL_ENABLED=false
OTEL_SERVICE_NAME=recall-ingest-bridge
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# --- Honeycomb (optional OTLP backend) ---
HONEYCOMB_API_KEY=
HONEYCOMB_DATASET=
HONEYCOMB_API_ENDPOINT=https://api.honeycomb.io

# ==============================================================================
# Observability — Langfuse LLM Tracing
# ==============================================================================
RECALL_LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ==============================================================================
# Network
# ==============================================================================
TAILSCALE_IP=
