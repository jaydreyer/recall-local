{
  "manifest_version": 3,
  "name": "Recall.local Capture",
  "version": "0.1.0",
  "description": "Capture pages, links, and selections into Recall.local in two clicks.",
  "action": {
    "default_title": "Capture with Recall.local",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "gmail.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "open-recall-popup": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "Open Recall.local capture popup"
    }
  }
}
